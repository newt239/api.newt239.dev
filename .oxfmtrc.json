{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["node_modules/", ".wrangler/", "dist/", "build/"],
  "sortImports": {
    "groups": [
      ["value-builtin", "value-external"],
      "value-internal",
      ["value-parent", "value-sibling", "value-index"],
      ["type-parent", "type-sibling", "type-index"],
      "type-internal",
      "type-import",
      "unknown"
    ],
    "internalPattern": ["~/"],
    "newlinesBetween": true,
    "order": "asc",
    "ignoreCase": true
  },
  "sortPackageJson": {
    "sortScripts": true
  }
}
